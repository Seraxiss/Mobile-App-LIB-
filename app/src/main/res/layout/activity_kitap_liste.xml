<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="?android:attr/colorBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp">

        <ImageView
            android:id="@+id/btnGeriOk"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:text="Kitap Listesi"
            android:textSize="26sp"
            android:textColor="?android:attr/textColorPrimary"
            android:textStyle="bold"
            android:layout_centerInParent="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="15dp">

        <EditText
            android:id="@+id/txtArama"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="50dp"
            android:hint="Kitap Ara (Örn: Harry Potter)"
            android:drawableLeft="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:background="@drawable/bg_custom_input"/>

        <ImageView
            android:id="@+id/btnSesliArama"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:scrollbars="none">
        
        <LinearLayout
            android:id="@+id/kategoriKapsayici"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCatTumu"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Tümü"
                android:background="@color/purple_500"
                android:textColor="@android:color/white"
                android:layout_marginEnd="8dp"/>
                
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCatRoman"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Roman"
                android:background="?android:attr/colorButtonNormal"
                android:layout_marginEnd="8dp"/>
                
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCatBilim"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Bilim"
                android:background="?android:attr/colorButtonNormal"
                android:layout_marginEnd="8dp"/>
                
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCatTarih"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Tarih"
                android:background="?android:attr/colorButtonNormal"
                android:layout_marginEnd="8dp"/>
                
        </LinearLayout>
    </HorizontalScrollView>

    <ListView
        android:id="@+id/listViewKitaplar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="?android:attr/listDivider"
        android:dividerHeight="1dp"
        android:layout_marginBottom="15dp"/>
        
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnKitapDuzenle"
        android:text="Kitap Düzenle"
        android:textColor="@android:color/white"
        android:background="@drawable/bg_custom_button"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="10dp"/>
        
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnKitapKaldir"
        android:text="Kitap Kaldır"
        android:textColor="@android:color/white"
        android:background="@drawable/bg_custom_button_red"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="10dp"/>
        
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnGeri"
        android:text="Ana Menüye Dön"
        android:textColor="@android:color/white"
        android:background="@drawable/bg_custom_button"
        android:layout_width="match_parent"
        android:layout_height="50dp"/>

</LinearLayout>