<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground"
    android:padding="30dp">

    <TextView
        android:text="Kütüphane Uygulaması v1.0"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:textAlignment="center"
        android:layout_marginBottom="15dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:text="Bu uygulama Android Studio ve SQLite veritabanı altyapısı kullanılarak özel olarak tasarlanmıştır. İçerisinde üye kayıt, giriş yapma, kitap ekleme, dinamik listeleme ve kitap silme fonksiyonları barındırır."
        android:textSize="17sp"
        android:textColor="?android:attr/textColorSecondary"
        android:textAlignment="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnGeri"
        android:text="Ana Menüye Dön"
        android:textColor="@android:color/white"
        android:background="@drawable/bg_custom_button"
        android:layout_width="200dp"
        android:layout_height="50dp"/>

</LinearLayout>