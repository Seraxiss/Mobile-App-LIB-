<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="?android:attr/colorBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:text="Sistem İstatistikleri"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_gravity="center"
        android:layout_marginBottom="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="15dp"
        android:weightSum="2">

        <!-- Toplam Üye -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_custom_input"
            android:layout_marginEnd="10dp">
            
            <TextView
                android:text="Toplam Üye"
                android:textSize="16sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
                
            <TextView
                android:id="@+id/txtToplamUye"
                android:text="0"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#3F51B5"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Toplam Kitap -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_custom_input"
            android:layout_marginStart="10dp">

            <TextView
                android:text="Toplam Kitap"
                android:textSize="16sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtToplamKitap"
                android:text="0"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="40dp"
        android:weightSum="2">

        <!-- Rafta Kalan -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_custom_input"
            android:layout_marginEnd="10dp">

            <TextView
                android:text="Rafta Kalan"
                android:textSize="16sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtRafta"
                android:text="0"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#03A9F4"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Ödünç Verilen -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_custom_input"
            android:layout_marginStart="10dp">

            <TextView
                android:text="Ödünçte"
                android:textSize="16sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtOduncte"
                android:text="0"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#F44336"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_custom_input"
        android:padding="15dp"
        android:layout_marginBottom="30dp">

        <TextView
            android:text="Kütüphane Ödünç Doluluk Oranı"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <ProgressBar
            android:id="@+id/progressBarOdunc"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:progressDrawable="@android:drawable/progress_horizontal"
            android:max="100"
            android:progress="0" />

        <TextView
            android:id="@+id/txtYuzde"
            android:text="%0"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_gravity="end"
            android:layout_marginTop="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnGeriDon"
        android:text="Ana Menüye Dön"
        android:textColor="@android:color/white"
        android:background="@drawable/bg_custom_button"
        android:layout_width="match_parent"
        android:layout_height="50dp"/>

</LinearLayout>
